# Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Must be YOUR personal numeric user id from @userinfobot — not another bot’s id
# (Telegram does not allow bots to message bots.)
TELEGRAM_CHAT_ID=your_chat_id_here

# Trading capital (₹) — used when risk_state.json does NOT exist (e.g. Render / first deploy).
# Set this on your live server; do not commit risk_state.json (it's gitignored).
CAPITAL=1000

# If risk_state.json already exists and you still want env to override capital (rare):
# FORCE_CAPITAL_FROM_ENV=1

# --- Crypto: ZebPay INR only (public klines) ---
# ZEBPAY_QUOTE=INR
# Override watchlist (comma-separated). If unset:
#   CRYPTO_WATCHLIST_MODE=xpress     (default: Xpress INR list + QuickTrade MARKET pairs)
#   CRYPTO_WATCHLIST_MODE=quicktrade (~7 symbols: MARKET INR only — faster)
#   CRYPTO_WATCHLIST_MODE=all        (all Open INR bases from exchangeInfo, capped)
# Optional: replace built-in Xpress list (comma bases, e.g. TURBO,PEPE,SHIB)
# ZEBPAY_XPRESS_SYMBOLS=TURBO,MBL,PEPE,SHIB
# CRYPTO_WATCHLIST=BTC,ETH,SOL
# CRYPTO_WATCHLIST_MAX=120
