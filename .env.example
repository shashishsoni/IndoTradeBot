# Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Must be YOUR personal numeric user id from @userinfobot — not another bot’s id
# (Telegram does not allow bots to message bots.)
TELEGRAM_CHAT_ID=your_chat_id_here

# Trading capital (₹) — used when risk_state.json does NOT exist (e.g. Render / first deploy).
# Set this on your live server; do not commit risk_state.json (it's gitignored).
CAPITAL=1000

# If risk_state.json already exists and you still want env to override capital (rare):
# FORCE_CAPITAL_FROM_ENV=1

# --- Optional: crypto OHLCV source (default: binance) ---
# ZebPay Spot public klines (INR pairs, no API key). See docs/ZEBPAY.md
# CRYPTO_DATA_SOURCE=zebpay
# If ZebPay fails for a symbol, fall back to Binance (default on). Set to 0 to disable.
# ZEBPAY_FALLBACK_BINANCE=1
# Quote for auto-mapped symbols (BTCUSDT -> BTC-INR)
# ZEBPAY_QUOTE=INR
